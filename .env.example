# Variáveis de ambiente do JEC Gestão.
# Copie para .env (local) e configure os mesmos valores na Vercel (produção).

# Supabase (banco de dados)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_publishable

# Endereço do backend (servidor de PDF/OCR/petições/índices).
# Local: http://localhost:3001 | Produção: https://SEU-BACKEND.onrender.com
VITE_API_URL=http://localhost:3001

# Cadeado de acesso (senha única). Se vazio, o app abre sem senha.
VITE_APP_PASSWORD=defina_uma_senha_forte
